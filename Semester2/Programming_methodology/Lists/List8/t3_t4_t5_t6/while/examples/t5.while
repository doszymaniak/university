xs = {7; 2; 1; 6; 5; 3; 4};
length = 7;

i = 0;
while (i < length)
{
    j = 1;
    while (j < length - i)
    {
        if (xs[j - 1] > xs[j])
        {
            temp = xs[j - 1];
            xs[j - 1] = xs[j];
            xs[j] = temp;
        }
        else
        {
            skip;
        }
        j = j + 1;
    }
    i = i + 1;
}

print(xs);
print("\n");